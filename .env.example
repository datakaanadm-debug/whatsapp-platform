# =================================================================
# WhatsApp Platform — Variables de Entorno
# Copia este archivo como .env y configura los valores
# =================================================================

# ── PostgreSQL ────────────────────────────────────────────────────
POSTGRES_DB=whatsapp_platform
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_PORT=5432

# URL de conexion completa (usada por la API y el Worker)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/whatsapp_platform

# ── Redis ─────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
REDIS_PORT=6379

# ── API FastAPI ───────────────────────────────────────────────────
PORT=8000
ENVIRONMENT=development
LOG_LEVEL=INFO

# ── Autenticacion JWT ─────────────────────────────────────────────
# Cambiar en produccion por un secreto seguro (min 32 caracteres)
JWT_SECRET=cambiar-en-produccion-secreto-seguro-de-al-menos-32-caracteres
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=1440

# ── API Key ───────────────────────────────────────────────────────
API_KEY_HEADER=X-API-Key

# ── CORS ──────────────────────────────────────────────────────────
# Origenes permitidos (separados por coma)
CORS_ORIGINS=["http://localhost:3000","http://localhost:8000"]

# ── Rate Limiting ─────────────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_HOUR=1000

# ── Almacenamiento S3 (compatible con MinIO) ──────────────────────
# Dejar vacio para usar almacenamiento local en ./media
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=whatsapp-media
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_REGION=us-east-1

# ── Almacenamiento local de medios (fallback si no hay S3) ────────
MEDIA_STORAGE_PATH=./media

# ── Anthropic API (para agentes con IA) ──────────────────────────
# Obtener en: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# ── Webhooks ──────────────────────────────────────────────────────
WEBHOOK_RETRY_MAX=5
WEBHOOK_RETRY_DELAY=30
